{
  "Dhcp4": {
    "interfaces-config": {
      "interfaces": [ "{{ kea_dhcp4_interface | default(keepalived_interface) }}" ]
    },
    "control-sockets": [
      {
        "socket-type": "http",
        "socket-address": "{{ kea_dhcp4_control_address | default('127.0.0.1') }}",
        "socket-port": {{ kea_dhcp4_control_port | default(8010) }}
      }
    ],
    "lease-database": {
      "type": "memfile",
      "name": "/var/lib/kea/kea-leases4.csv",
      "persist": true,
      "lfc-interval": {{ kea_dhcp4_lfc_interval | default(3600) }}
    },
    "valid-lifetime": {{ kea_dhcp4_valid_lifetime | default(3600) }},
    "renew-timer": {{ kea_dhcp4_renew_timer | default(900) }},
    "rebind-timer": {{ kea_dhcp4_rebind_timer | default(1800) }},
    "store-extended-info": true,
    "hooks-libraries": [
      {
        "library": "libdhcp_lease_cmds.so"
      },
      {
        "library": "libdhcp_ha.so",
        "parameters": {
          "high-availability": [
            {
              "this-server-name": "{{ inventory_hostname }}",
              "mode": "hot-standby",
              "heartbeat-delay": {{ kea_dhcp4_heartbeat_delay | default(10000) }},
              "max-response-delay": {{ kea_dhcp4_max_response_delay | default(60000) }},
              "max-ack-delay": {{ kea_dhcp4_max_ack_delay | default(5000) }},
              "max-unacked-clients": {{ kea_dhcp4_max_unacked_clients | default(5) }},
              "max-rejected-lease-updates": {{ kea_dhcp4_max_rejected_lease_updates | default(10) }},
              "multi-threading": {
                "enable-multi-threading": true,
                "http-dedicated-listener": true,
                "http-listener-threads": 0,
                "http-client-threads": 0
              },
              "peers": [
                {
                  "name": "{{ groups['dhcp'][0] }}",
                  "url": "http://{{ hostvars[groups['dhcp'][0]].ansible_host }}:{{ kea_dhcp4_ha_port | default(8001) }}/",
                  "role": "primary",
                  "auto-failover": true
                },
                {
                  "name": "{{ groups['dhcp'][1] }}",
                  "url": "http://{{ hostvars[groups['dhcp'][1]].ansible_host }}:{{ kea_dhcp4_ha_port | default(8001) }}/",
                  "role": "standby",
                  "auto-failover": true
                }
              ]
            }
          ]
        }
      }
    ],
{% if kea_dhcp4_pxe_next_server is defined or kea_dhcp4_http_boot_url_base is defined %}
    "client-classes": [
      {
        "name": "httpboot_uefi_x64",
        "test": "substring(option[60].hex,0,10) == 'HTTPClient' and (option[93].hex == 0x0007 or option[93].hex == 0x0009)",
        "boot-file-name": "{{ kea_dhcp4_http_boot_uefi_x64_boot_file_name | default(((kea_dhcp4_http_boot_url_base if kea_dhcp4_http_boot_url_base is defined else 'http://' ~ kea_dhcp4_pxe_next_server)) ~ '/netboot.xyz.efi') }}",
        "option-data": [
          {
            "name": "vendor-class-identifier",
            "data": "HTTPClient",
            "always-send": true
          }
        ]
      },
      {
        "name": "httpboot_uefi_arm64",
        "test": "substring(option[60].hex,0,10) == 'HTTPClient' and option[93].hex == 0x000b",
        "boot-file-name": "{{ kea_dhcp4_http_boot_uefi_arm64_boot_file_name | default(((kea_dhcp4_http_boot_url_base if kea_dhcp4_http_boot_url_base is defined else 'http://' ~ kea_dhcp4_pxe_next_server)) ~ '/netboot.xyz-arm64.efi') }}",
        "option-data": [
          {
            "name": "vendor-class-identifier",
            "data": "HTTPClient",
            "always-send": true
          }
        ]
      }{% if kea_dhcp4_pxe_next_server is defined %},
      {
        "name": "pxe_uefi_x64",
        "test": "option[93].hex == 0x0007 or option[93].hex == 0x0009",
        "next-server": "{{ kea_dhcp4_pxe_next_server }}",
        "boot-file-name": "{{ kea_dhcp4_pxe_uefi_x64_boot_file_name | default('netboot.xyz-snponly.efi') }}"
      },
      {
        "name": "pxe_uefi_arm64",
        "test": "option[93].hex == 0x000b",
        "next-server": "{{ kea_dhcp4_pxe_next_server }}",
        "boot-file-name": "{{ kea_dhcp4_pxe_uefi_arm64_boot_file_name | default('netboot.xyz-arm64-snponly.efi') }}"
      },
      {
        "name": "pxe_bios",
        "test": "substring(option[60].hex,0,9) == 'PXEClient' and not member('pxe_uefi_x64') and not member('pxe_uefi_arm64')",
        "next-server": "{{ kea_dhcp4_pxe_next_server }}",
        "boot-file-name": "{{ kea_dhcp4_pxe_bios_boot_file_name | default('netboot.xyz.kpxe') }}"
      }{% endif %}
    ],
{% endif %}
    "subnet4": [
      {
        "id": {{ kea_dhcp4_subnet_id | default(1) }},
        "subnet": "{{ kea_dhcp4_subnet }}",
        "interface": "{{ kea_dhcp4_interface | default(keepalived_interface) }}"{% if kea_dhcp4_match_client_id is defined %},
        "match-client-id": {{ (kea_dhcp4_match_client_id | bool) | ternary('true', 'false') }}{% endif %},
        "pools": [
          {
            "pool": "{{ kea_dhcp4_pool }}"
          }
        ],
        "option-data": [
          {
            "name": "routers",
            "data": "{{ kea_dhcp4_router }}"
          }{% if kea_dhcp4_dns_servers is defined %},
          {
            "name": "domain-name-servers",
            "data": "{{ kea_dhcp4_dns_servers | join(', ') }}"
          }{% endif %}{% if kea_dhcp4_domain_name is defined %},
          {
            "name": "domain-name",
            "data": "{{ kea_dhcp4_domain_name }}"
          }{% endif %}
        ]{% if kea_dhcp4_next_server is defined %},
        "next-server": "{{ kea_dhcp4_next_server }}"{% endif %}{% if kea_dhcp4_boot_file_name is defined %},
        "boot-file-name": "{{ kea_dhcp4_boot_file_name }}"{% endif %}
      }
    ],
    "loggers": [
      {
        "name": "kea-dhcp4",
        "output_options": [
          {
            "output": "{{ kea_dhcp4_log_output | default('/var/log/kea/kea-dhcp4.log') }}"
          }
        ],
        "severity": "{{ kea_dhcp4_log_severity | default('INFO') }}"
      }
    ]
  }
}